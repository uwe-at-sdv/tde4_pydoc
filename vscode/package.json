{
  "name": "tde4-pydoc",
  "displayName": "3DE4 Python API",
  "description": "VS Code MCP provider for the 3DE4 Python API documentation.",
  "version": "0.1.4",
  "publisher": "uwe-at-sdv",
  "icon": "img/tde4_pydoc.logo.png",
  "engines": {
    "vscode": "^1.115.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "configuration": {
      "title": "3DE4 Python API",
      "properties": {
        "tde4.mcpProvideServer": {
          "type": "boolean",
          "default": true,
          "description": "Register a Waterloo MCP stdio server definition in VS Code."
        },
        "tde4.mcpCommand": {
          "type": "string",
          "default": "wtrl_mcp",
          "description": "Command used to start the MCP server."
        },
        "tde4.mcpConfigPath": {
          "type": "string",
          "default": "",
          "description": "Path to wtrl_mcp.stdio.toml. If empty, the extension falls back to ./etc/wtrl_mcp.stdio.toml."
        },
        "tde4.mcpServerLabel": {
          "type": "string",
          "default": "3DE4 Python API (stdio)",
          "description": "Label shown for the MCP server inside VS Code."
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "tde4-pydoc.mcpProvider",
        "label": "3DE4 Python API MCP Provider"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uwe-at-sdv/tde4_pydoc.git"
  },
  "license": "BSD-2-Clause"
}
