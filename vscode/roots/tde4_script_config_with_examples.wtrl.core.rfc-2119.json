            "hash": "ff114b2ee9f40d03492fd989be351f72208fe8af1da714575492cf8088966c6e",
            "code": "# 3DE4.script.name:\ttde4_t4sc_3de4\n# 3DE4.script.version:\tv0.1.0\n# 3DE4.script.comment:\tSmoke test for tde4_script_config\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom typing import Any\n\nimport tde4\nimport tde4_script_config as t4sc\n\n\n@dataclass(frozen=True)\nclass FieldSpec:\n\ttag: str\n\tindex_path: tuple[int | str, ...]\n\tvalue_type: str\n\twidget_name: str\n\n\tdef label(self) -> str:\n\t\tindex_text = \" \".join(repr(index) for index in self.index_path)\n\t\tif index_text:\n\t\t\treturn f\"{self.tag} {index_text} [{self.value_type}]\"\n\t\treturn f\"{self.tag} [{self.value_type}]\"\n\n\nCONFIG_ID = \"tde4_t4sc_3de4\"\nFIELDS = (\n\tFieldSpec(\"MyTag\", (\"A\", \"1\"), \"string\", \"value_0\"),\n\tFieldSpec(\"MyTag\", (\"A\", 2), \"int\", \"value_1\"),\n\tFieldSpec(\"MyTag\", (3,), \"float\", \"value_2\"),\n\tFieldSpec(\"OtherTag\", (\"B\", \"2\"), \"string\", \"value_3\"),\n\tFieldSpec(\"OtherTag\", (4,), \"int\", \"value_4\"),\n)\n\n\ndef _format_value(value: int | float | str) -> str:\n\treturn str(value)\n\n\ndef _parse_value(raw: str, value_type: str) -> int | float | str:\n\tif value_type == \"string\":\n\t\treturn raw\n\tif value_type == \"int\":\n\t\treturn int(raw)\n\tif value_type == \"float\":\n\t\treturn float(raw)\n\traise ValueError(f\"Unsupported value type: {value_type!r}\")\n\n\ndef _load_config_values(requester: Any, config: t4sc.tde4_config) -> None:\n\tfor field in FIELDS:\n\t\tvalue = config.get(field.tag, *field.index_path)\n\t\tif value is t4sc.config.undefined:\n\t\t\tcontinue\n\t\ttde4.setWidgetValue(requester, field.widget_name, _format_value(value))\n\n\ndef _read_draft_values(requester: Any) -> dict[FieldSpec, int | float | str]:\n\tdraft: dict[FieldSpec, int | float | str] = {}\n\tfor field in FIELDS:\n\t\traw = tde4.getWidgetValue(requester, field.widget_name)\n\t\tdraft[field] = _parse_value(str(raw), field.value_type)\n\treturn draft\n\n\ndef _write_config_values(config: t4sc.tde4_config, values: dict[FieldSpec, int | float | str]) -> None:\n\tfor field, value in values.items():\n\t\tconfig.set(field.tag, value, *field.index_path)\n\tconfig.flush()\n\n\ndef main() -> None:\n\tconfig = t4sc.tde4_config(CONFIG_ID)\n\trequester = tde4.createCustomRequester()\n\ttry:\n\t\tfor field in FIELDS:\n\t\t\ttde4.addTextFieldWidget(requester, field.widget_name, field.label(), \"\")\n\t\t_load_config_values(requester, config)\n\t\twhile True:\n\t\t\tbutton = tde4.postCustomRequester(requester, \"tde4_t4sc_3de4\", 760, 220, \"OK\", \"Cancel\")\n\t\t\tif button != 1:\n\t\t\t\tbreak\n\t\t\ttry:\n\t\t\t\tdraft_values = _read_draft_values(requester)\n\t\t\texcept ValueError as exc:\n\t\t\t\ttde4.postQuestionRequester(\"tde4_t4sc_3de4\", f\"Invalid value: {exc}\", \"OK\")\n\t\t\t\tcontinue\n\t\t\t_write_config_values(config, draft_values)\n\t\t\tbreak\n\tfinally:\n\t\ttde4.deleteCustomRequester(requester)\n\n\nmain()\n",
            "referenced_by": [
                "tde4_script_config.config"
            ]
        }
